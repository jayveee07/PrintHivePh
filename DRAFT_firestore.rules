rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'status', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 2000 &&
             data.status == 'unread' &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'stock', 'imageUrl', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.uid == request.auth.uid &&
             data.role == 'user'; // Users cannot self-promote to admin
    }

    // Rules for Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed manually or through a super-admin process (not implemented)
    }

    // Rules for Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
                    incoming().role == existing().role && // Immutable role
                    incoming().uid == existing().uid;
    }

    // Rules for Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Rules for Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Inquiries
    match /inquiries/{inquiryId} {
      allow get, list: if isAdmin();
      allow create: if isValidInquiry(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for Transactions (Admin Only)
    match /transactions/{transactionId} {
      allow read, write: if isAdmin();
    }

    // Rules for Expenses (Admin Only)
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    // Rules for Portfolio
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
