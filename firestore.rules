rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Hardcoded admin check for bootstrap and production fallback
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '8Ajzo3JgCre3CXgIwI7entja1yr2' || 
        request.auth.uid == 'ux0ysOYCeTYKFFHO9BCWqrM08f32' || 
        request.auth.uid == 'KtvVHRSr28X8i4b3jd84F4gK7953' ||
        request.auth.token.email == 'jvpaisan@gmail.com' || 
        request.auth.token.email == 'printhiveph.2026@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- COLLECTION RULES ---

    // 1. PRODUCTS - Publicly readable
    match /products/{productId=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. ORDERS - User sees own, Admin sees all
    match /orders/{orderId=**} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow write: if isAdmin();
    }

    // 3. USERS - User owns doc, Admin sees all
    match /users/{userId} {
      allow read, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
    }

    // 4. INQUIRIES - Anyone creates, Admin manages
    match /inquiries/{inquiryId=**} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // 5. OTHER COLLECTIONS 
    match /categories/{id=**} { allow read: if true; allow write: if isAdmin(); }
    match /services/{id=**} { allow read: if true; allow write: if isAdmin(); }
    match /portfolio/{id=**} { allow read: if true; allow write: if isAdmin(); }
    
    match /expenses/{id=**} { allow read, write: if isAdmin(); }
    match /transactions/{id=**} { allow read, write: if isAdmin(); }
    
    match /admins/{id=**} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /activity_logs/{logId=**} {
      allow read, create: if isAdmin();
    }

    // 6. DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 7. TEST CONNECTION
    match /test/{id} {
      allow read, write: if true;
    }
  }
}
